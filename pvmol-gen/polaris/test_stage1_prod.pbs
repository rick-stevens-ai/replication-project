#!/bin/bash -l
#PBS -l select=10:system=polaris
#PBS -l walltime=01:00:00
#PBS -l filesystems=home
#PBS -q prod
#PBS -A IMPROVE_Aim1
#PBS -N pvmol-stage1-prod
#PBS -o /home/stevens/pvmol-gen/logs/stage1_prod.out
#PBS -e /home/stevens/pvmol-gen/logs/stage1_prod.err

module load conda
conda activate base

cd /home/stevens/pvmol-gen
mkdir -p logs

echo "=== PVMol-Gen Stage 1 Classifier (prod queue) ==="
echo "Host: $(hostname)"
echo "Date: $(date)"
nvidia-smi --query-gpu=name,memory.total --format=csv,noheader

# Note: prod requires minimum 10 nodes. This runs on rank 0 only.
# For real multi-node work, use mpiexec.
python src/stage1_classifier.py 2>&1 | tee logs/stage1_prod_$(date +%Y%m%d_%H%M%S).log

echo "Finished at: $(date)"
