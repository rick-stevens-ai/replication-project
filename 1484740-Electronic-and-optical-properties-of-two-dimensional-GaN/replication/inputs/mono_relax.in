&CONTROL
    calculation = 'vc-relax',
    prefix = 'gan_mono',
    pseudo_dir = '/home/stevens/replication/pseudopotentials/',
    outdir = '/home/stevens/replication/outputs/mono_relax/',
    tprnfor = .true.,
    tstress = .true.,
    forc_conv_thr = 1.0d-4,
    etot_conv_thr = 1.0d-6,
/
&SYSTEM
    ibrav = 0,
    nat = 4,
    ntyp = 3,
    ecutwfc = 80.0,
    ecutrho = 320.0,
    occupations = 'fixed',
    input_dft = 'PBE',
    assume_isolated = '2D',
/
&ELECTRONS
    conv_thr = 1.0d-10,
    mixing_beta = 0.3,
    electron_maxstep = 200,
/
&IONS
    ion_dynamics = 'bfgs',
/
&CELL
    cell_dynamics = 'bfgs',
    cell_dofree = '2Dxy',
    press_conv_thr = 0.1,
/
ATOMIC_SPECIES
    Ga  69.723  Ga_ONCV_PBE_sr.upf
    N   14.007  N_ONCV_PBE_sr.upf
    H    1.008  H_ONCV_PBE_sr.upf
CELL_PARAMETERS (angstrom)
    3.200000    0.000000    0.000000
   -1.600000    2.771281    0.000000
    0.000000    0.000000   20.000000
ATOMIC_POSITIONS (crystal)
    Ga  0.333333  0.666667  0.500000
    N   0.666667  0.333333  0.516500
    H   0.333333  0.666667  0.422500
    H   0.666667  0.333333  0.594000
K_POINTS (automatic)
    8  8  1  0  0  0
