&CONTROL
    calculation = 'vc-relax',
    prefix = 'gan_bi',
    pseudo_dir = '/home/stevens/replication/pseudopotentials/',
    outdir = '/home/stevens/replication/outputs/bi_relax/',
    tprnfor = .true.,
    tstress = .true.,
    forc_conv_thr = 1.0d-3,
    etot_conv_thr = 1.0d-5,
/
&SYSTEM
    ibrav = 0,
    nat = 6,
    ntyp = 3,
    ecutwfc = 60.0,
    ecutrho = 240.0,
    occupations = 'fixed',
    input_dft = 'PBE',
    assume_isolated = '2D',
/
&ELECTRONS
    conv_thr = 1.0d-8,
    mixing_beta = 0.3,
    electron_maxstep = 200,
/
&IONS
    ion_dynamics = 'bfgs',
/
&CELL
    cell_dynamics = 'bfgs',
    cell_dofree = '2Dxy',
    press_conv_thr = 0.5,
/
ATOMIC_SPECIES
    Ga  69.723  Ga_ONCV_PBE_sr.upf
    N   14.007  N_ONCV_PBE_sr.upf
    H    1.008  H_ONCV_PBE_sr.upf
CELL_PARAMETERS (angstrom)
    3.200000    0.000000    0.000000
   -1.600000    2.771281    0.000000
    0.000000    0.000000   25.000000
ATOMIC_POSITIONS (crystal)
    H   0.333333  0.666667  0.356000
    Ga  0.333333  0.666667  0.420000
    N   0.666667  0.333333  0.433200
    N   0.333333  0.666667  0.521200
    Ga  0.666667  0.333333  0.534800
    H   0.666667  0.333333  0.596800
K_POINTS (automatic)
    6  6  1  0  0  0
