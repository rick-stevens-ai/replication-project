&CONTROL
    calculation = 'relax',
    prefix = 'gan_bi',
    pseudo_dir = '/home/stevens/replication/pseudopotentials/',
    outdir = '/home/stevens/replication/outputs/bi_relax2/',
    tprnfor = .true.,
    tstress = .true.,
    forc_conv_thr = 1.0d-3,
    etot_conv_thr = 1.0d-5,
    nstep = 100,
    restart_mode = 'from_scratch',
    verbosity = 'default',
/
&SYSTEM
    ibrav = 0,
    nat = 6,
    ntyp = 3,
    ecutwfc = 60.0,
    ecutrho = 240.0,
    occupations = 'fixed',
    input_dft = 'PBE',
    assume_isolated = '2D',
/
