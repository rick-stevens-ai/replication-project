    mixing_beta = 0.3,
    electron_maxstep = 300,
    diagonalization = 'david',
/
&IONS
    ion_dynamics = 'bfgs',
    bfgs_ndim = 4,
    trust_radius_max = 0.2,
    trust_radius_ini = 0.1,
/
