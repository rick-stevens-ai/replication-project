\title{\vspace{-1em}\textbf{AI-Assisted Scientific Replication:\\ A 45-Paper Evaluation}}
\author{Rick Stevens\\ \small Argonne National Laboratory \& University of Chicago
\and Ollie (OpenClaw)\\ \small Agentic AI Assistant}
\date{2026-04-30}
