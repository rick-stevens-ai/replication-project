&CONTROL
    calculation = 'bands',
    prefix = 'gan_bi',
    pseudo_dir = '/home/stevens/replication/pseudopotentials/',
    outdir = '/home/stevens/replication/outputs/bi_scf/',
    verbosity = 'high',
/
&SYSTEM
    ibrav = 0,
    nat = 6,
    ntyp = 3,
    ecutwfc = 60.0,
    ecutrho = 240.0,
    occupations = 'fixed',
    input_dft = 'PBE',
    assume_isolated = '2D',
    nbnd = 40,
/
&ELECTRONS
    conv_thr = 1.0d-9,
    diago_full_acc = .true.,
/
ATOMIC_SPECIES
    Ga  69.723  Ga_ONCV_PBE_sr.upf
    N   14.007  N_ONCV_PBE_sr.upf
    H    1.008  H_ONCV_PBE_sr.upf
@CELL_PARAMS@
@ATOMIC_POSITIONS@
K_POINTS {crystal_b}
4
0.000000  0.000000  0.0  40   ! Gamma
0.500000  0.000000  0.0  40   ! M
0.333333  0.333333  0.0  40   ! K
0.000000  0.000000  0.0  1    ! Gamma
