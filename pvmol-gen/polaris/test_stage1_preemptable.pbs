#!/bin/bash -l
#PBS -l select=1:system=polaris
#PBS -l walltime=01:00:00
#PBS -l filesystems=home
#PBS -q preemptable
#PBS -A IMPROVE_Aim1
#PBS -N pvmol-stage1-pre
#PBS -o /home/stevens/pvmol-gen/logs/stage1_preemptable.out
#PBS -e /home/stevens/pvmol-gen/logs/stage1_preemptable.err

module load conda
conda activate base

cd /home/stevens/pvmol-gen
mkdir -p logs

echo "=== PVMol-Gen Stage 1 Classifier (preemptable queue) ==="
echo "Host: $(hostname)"
echo "Date: $(date)"
nvidia-smi --query-gpu=name,memory.total --format=csv,noheader

python src/stage1_classifier.py 2>&1 | tee logs/stage1_preemptable_$(date +%Y%m%d_%H%M%S).log

echo "Finished at: $(date)"
