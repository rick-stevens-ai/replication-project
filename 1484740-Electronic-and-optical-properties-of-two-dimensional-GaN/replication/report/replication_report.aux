\@writefile{toc}{\contentsline {section}{\numberline {3}Electronic Properties}{3}{section.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.1}DFT Band Gap}{3}{subsection.3.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces DFT band gaps of 2D GaN (direct gap at $\Gamma $)}}{3}{table.caption.4}\protected@file@percent }
