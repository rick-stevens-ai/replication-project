&CONTROL
    calculation = 'vc-relax',
    prefix = 'gan_bi',
    pseudo_dir = '/home/stevens/replication/pseudopotentials/',
    outdir = '/home/stevens/replication/outputs/bi_relax/',
    tprnfor = .true.,
    tstress = .true.,
    forc_conv_thr = 1.0d-3,
    etot_conv_thr = 1.0d-5,
    nstep = 200,
    restart_mode = 'from_scratch',
    verbosity = 'default',
/
&SYSTEM
    ibrav = 0,
    nat = 6,
    ntyp = 3,
    ecutwfc = 60.0,
    ecutrho = 240.0,
    occupations = 'fixed',
    input_dft = 'PBE',
    assume_isolated = '2D',
/
&ELECTRONS
    conv_thr = 1.0d-10,
    mixing_beta = 0.3,
    electron_maxstep = 250,
    diagonalization = 'david',
/
&IONS
    ion_dynamics = 'bfgs',
    bfgs_ndim = 3,
    trust_radius_max = 0.2,
/
&CELL
    cell_dynamics = 'bfgs',
    cell_dofree = '2Dxy',
    press_conv_thr = 0.1,
/
