#!/bin/bash -l
#PBS -l select=1:system=polaris
#PBS -l walltime=01:00:00
#PBS -l filesystems=home
#PBS -q debug
#PBS -A IMPROVE_Aim1
#PBS -N pvmol-stage2-test
#PBS -o /home/stevens/pvmol-gen/logs/stage2_test.out
#PBS -e /home/stevens/pvmol-gen/logs/stage2_test.err

module load conda
conda activate base

cd /home/stevens/pvmol-gen
mkdir -p logs

echo "=== PVMol-Gen Stage 2 Generator Test ==="
echo "Host: $(hostname)"
echo "Date: $(date)"
nvidia-smi --query-gpu=name,memory.total --format=csv,noheader

# Stage 2: fine-tune GPT-2 on T1, then generate
# Using all 4 GPUs on the node
echo ""
echo "=== Running Stage 2 Generator (Cycle 1) ==="
python src/stage2_generator.py 2>&1 | tee logs/stage2_test_$(date +%Y%m%d_%H%M%S).log

echo ""
echo "=== Done ==="
echo "Finished at: $(date)"
