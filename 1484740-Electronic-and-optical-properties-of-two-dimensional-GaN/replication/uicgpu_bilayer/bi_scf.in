&CONTROL
    calculation = 'scf',
    prefix = 'gan_bi',
    pseudo_dir = '/home/stevens/replication/pseudopotentials/',
    outdir = '/home/stevens/replication/outputs/bi_scf/',
    tprnfor = .true.,
    tstress = .true.,
    verbosity = 'high',
/
&SYSTEM
    ibrav = 0,
    nat = 6,
    ntyp = 3,
    ecutwfc = 60.0,
    ecutrho = 240.0,
    occupations = 'fixed',
    input_dft = 'PBE',
    assume_isolated = '2D',
    nbnd = 30,
/
&ELECTRONS
    conv_thr = 1.0d-10,
    mixing_beta = 0.3,
    electron_maxstep = 250,
/
ATOMIC_SPECIES
    Ga  69.723  Ga_ONCV_PBE_sr.upf
    N   14.007  N_ONCV_PBE_sr.upf
    H    1.008  H_ONCV_PBE_sr.upf
@CELL_PARAMS@
@ATOMIC_POSITIONS@
K_POINTS (automatic)
   12 12  1  0  0  0
