&CONTROL
    calculation = 'bands',
    prefix = 'gan_monolayer',
    pseudo_dir = '../pseudopotentials/',
    outdir = '../outputs/monolayer_scf/',
    disk_io = 'low',
/
&SYSTEM
    ibrav = 0,
    nat = 4,
    ntyp = 3,
    ecutwfc = 80.0,
    ecutrho = 320.0,
    occupations = 'fixed',
    assume_isolated = '2D',
    nbnd = 20,
/
&ELECTRONS
    conv_thr = 1.0d-10,
    mixing_beta = 0.3,
/
ATOMIC_SPECIES
    Ga  69.723  Ga.pz-dn-nc.UPF
    N   14.007  N.pz-nc.UPF
    H    1.008  H.pz-nc.UPF
CELL_PARAMETERS (angstrom)
    3.1600    0.0000    0.0000
   -1.5800    2.7362    0.0000
    0.0000    0.0000   20.0000
ATOMIC_POSITIONS (angstrom)
    Ga  0.0000  0.0000  10.0000
    N   0.0000  1.8241  10.3300
    H   0.0000  0.0000   8.4500
    H   0.0000  1.8241  11.8800
K_POINTS {crystal_b}
4
    0.0000  0.0000  0.0000  30  ! Gamma
    0.5000  0.0000  0.0000  30  ! M
    0.3333  0.3333  0.0000  30  ! K
    0.0000  0.0000  0.0000  1   ! Gamma
