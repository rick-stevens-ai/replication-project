\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Band Structure}{3}{subsection.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces DFT-PBE band structure of H-passivated monolayer 2D GaN. Blue lines: valence bands; red lines: conduction bands. The direct band gap of 2.99~eV occurs at the $\Gamma $ point. The top two valence bands are nearly degenerate at $\Gamma $ (N~2$p$ character), consistent with the $C_{3v}$ symmetry of the buckled structure.}}{4}{figure.caption.5}\protected@file@percent }
\newlabel{fig:bandstructure}{{1}{4}{DFT-PBE band structure of H-passivated monolayer 2D GaN. Blue lines: valence bands; red lines: conduction bands. The direct band gap of 2.99~eV occurs at the $\Gamma $ point. The top two valence bands are nearly degenerate at $\Gamma $ (N~2$p$ character), consistent with the $C_{3v}$ symmetry of the buckled structure}{figure.caption.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}Biaxial Strain Dependence}{4}{subsection.3.3}\protected@file@percent }
\newlabel{sec:strain}{{3.3}{4}{Biaxial Strain Dependence}{subsection.3.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces DFT band gap of monolayer 2D GaN as a function of biaxial in-plane strain. Our PBE results (red squares) show the same qualitative trend as the original LDA results (blue triangles, estimated from Figure~3 of Bayerl et al.): the gap peaks near zero strain and decreases under both compressive and tensile strain, with a slightly asymmetric profile.}}{5}{figure.caption.6}\protected@file@percent }
\newlabel{fig:strain}{{2}{5}{DFT band gap of monolayer 2D GaN as a function of biaxial in-plane strain. Our PBE results (red squares) show the same qualitative trend as the original LDA results (blue triangles, estimated from Figure~3 of Bayerl et al.): the gap peaks near zero strain and decreases under both compressive and tensile strain, with a slightly asymmetric profile}{figure.caption.6}{}}
