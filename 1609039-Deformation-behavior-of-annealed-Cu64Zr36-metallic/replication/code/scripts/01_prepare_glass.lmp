# =============================================================================
# Stage 1: Prepare amorphous Cu64Zr36 metallic glass
# 
# Protocol:
#   1. Create random Cu64Zr36 liquid (6750 atoms)
#   2. Equilibrate at 2000 K
#   3. Cool to 950 K at 10^12 K/s
#   4. Isothermal anneal at 950 K for 120 ns
#   5. Cool to 300 K at 10^12 K/s
#   6. Relax at 300 K for 1 ns
# =============================================================================

units           metal
atom_style      atomic
boundary        p p p

# Create simulation box with random Cu64Zr36
# Target: 4320 Cu + 2430 Zr = 6750 atoms total
# Cu64Zr36 → 64% Cu, 36% Zr
# Start with a LARGE box to avoid overlaps, then compress via NPT
variable        Lbox equal 80.0
region          box block 0 ${Lbox} 0 ${Lbox} 0 ${Lbox} units box
create_box      2 box
create_atoms    1 random 4320 12345 box overlap 1.5 maxtry 100000
create_atoms    2 random 2430 67890 box overlap 1.5 maxtry 100000

mass            1 63.546   # Cu
mass            2 91.224   # Zr

# =========================================
# Phase 0: Push-off with soft potential to remove any remaining overlaps
# =========================================
pair_style      soft 2.0
pair_coeff      * * 100.0
variable        prefactor equal ramp(0,100)
fix             soft_ramp all adapt 1 pair soft a * * v_prefactor

timestep        0.001
fix             nve_push all nve/limit 0.1
thermo          1000
run             10000
unfix           nve_push
unfix           soft_ramp

# =========================================
# Switch to EAM potential
# =========================================
pair_style      eam/fs
pair_coeff      * * ../potentials/Cu-Zr_Mendelev2009.eam.fs Cu Zr

# Minimize with EAM
minimize        1e-4 1e-6 5000 50000

# Timestep
timestep        0.001      # 1 fs (metal units: ps)

# Thermo output
thermo          10000
thermo_style    custom step temp press pe ke etotal vol density lx ly lz

# =========================================
# Step 1: Equilibrate liquid at 2000 K
# First compress from low density to target density via high-P NPT
# =========================================
velocity        all create 2000 54321 dist gaussian

# Compress at 2000K under high pressure to reach ~7 g/cm³
fix             compress all npt temp 2000 2000 0.1 iso 50000 0 1.0
run             50000      # 50 ps compression
unfix           compress

# Now equilibrate at zero pressure
fix             npt1 all npt temp 2000 2000 0.1 iso 0 0 1.0
run             100000     # 100 ps equilibration
unfix           npt1

# Save liquid state
write_data      liquid_2000K.data

# =========================================
# Step 2: Cool from 2000 K to 950 K
# Cooling rate: 10^12 K/s = 1 K/ps
# ΔT = 1050 K → time = 1050 ps = 1.05 ns
# =========================================
dump            cool1 all custom 50000 dump_cool1.lammpstrj id type x y z
fix             cool1 all npt temp 2000 950 0.1 iso 0 0 1.0
run             1050000    # 1.05 ns
unfix           cool1
undump          cool1

write_data      cooled_950K.data

# =========================================
# Step 3: Isothermal anneal at 950 K for 120 ns
# This is the critical long step (120M timesteps)
# Save PE every 1 ns for Fig 1
# =========================================
fix             anneal all npt temp 950 950 0.1 iso 0 0 1.0

# Dump snapshots for PDF analysis at key times
# 0 ns (start), 60 ns, 120 ns
dump            anneal_dump all custom 1000000 dump_anneal.lammpstrj id type x y z
# PE output every 100 ps
fix             pe_out all ave/time 100000 1 100000 c_thermo_pe file pe_vs_time.dat

run             120000000  # 120 ns

unfix           anneal
undump          anneal_dump
unfix           pe_out

write_data      annealed_950K_120ns.data

# =========================================
# Step 4: Cool from 950 K to 300 K
# ΔT = 650 K → time = 650 ps
# =========================================
fix             cool2 all npt temp 950 300 0.1 iso 0 0 1.0
dump            cool2_dump all custom 100000 dump_cool2.lammpstrj id type x y z
run             650000     # 0.65 ns
unfix           cool2
undump          cool2_dump

# =========================================
# Step 5: Relax at 300 K for 1 ns
# =========================================
fix             relax all npt temp 300 300 0.1 iso 0 0 1.0
run             1000000    # 1 ns
unfix           relax

write_data      glass_300K_final.data

print "=== Stage 1 Complete: Annealed Cu64Zr36 glass prepared ==="
